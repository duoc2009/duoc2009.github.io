        "jsCode": "let geminiText = '{}';\nif ($node['9A. AI Gemini Viết Báo (Free)'].json.candidates) {\n  geminiText = $node['9A. AI Gemini Viết Báo (Free)'].json.candidates[0].content.parts[0].text;\n}\n\nlet parsed = {};\ntry {\n  let match = geminiText.match(/\\{[\\s\\S]*\\}/);\n  if (match) parsed = JSON.parse(match[0]);\n} catch(e) {}\nif (!parsed.wp1) parsed.wp1 = {};\nif (!parsed.wp2) parsed.wp2 = {};\n\n// OpenRouter: upgrade titles\ntry {\n  let orRaw = $node['9B. AI OpenRouter Tối Ưu Title'].json.choices[0].message.content;\n  let orMatch = orRaw.match(/\\{[\\s\\S]*\\}/);\n  if (orMatch) {\n    let orP = JSON.parse(orMatch[0]);\n    if (orP.title1_viral) parsed.wp1.title = orP.title1_viral;\n    if (orP.title2_viral) parsed.wp2.title = orP.title2_viral;\n  }\n} catch(e) {}\n\n// Mistral: content quality tip\ntry {\n  let msRaw = $node['9D. AI Mistral Kiểm Tra Chất Lượng'].json.choices[0].message.content;\n  parsed.mistral_tip = msRaw.substring(0, 300);\n} catch(e) { parsed.mistral_tip = ''; }\n\n// DeepSeek: SEO score\ntry {\n  let dsRaw = $node['9C. AI DeepSeek Chấm SEO'].json.choices[0].message.content;\n  let dsMatch = dsRaw.match(/\\{[\\s\\S]*\\}/);\n  if (dsMatch) {\n    let dsP = JSON.parse(dsMatch[0]);\n    parsed.ds_score = dsP.score || 8;\n    parsed.ds_tip = dsP.tip || 'Tốt';\n  }\n} catch(e) { parsed.ds_score = 8; parsed.ds_tip = 'Chưa chấm được'; }\n\nparsed.ok = true;\nreturn [{ json: parsed }];"

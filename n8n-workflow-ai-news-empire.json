      "parameters": {
        "jsCode": "let feeds = [];\ntry {\n  for (let item of items) {\n    for (let key in item.json) {\n      if (typeof item.json[key] === 'string' && item.json[key].includes('http')) {\n        let match = item.json[key].match(/(https?:\\/\\/[^\\s]+)/);\n        if (match) { feeds.push({ json: { link_rss_chuan: match[1].trim() } }); break; }\n      }\n    }\n  }\n} catch(e) {}\nreturn feeds.sort(() => 0.5 - Math.random()).slice(0, 5);"
      },

      "parameters": {
        "jsCode": "let text = $input.first().json.data || '';\nlet linkMatch = text.match(/<link[^>]*>(.*?)<\\/link>|<link\\s+href=\"([^\"]+)\"/g);\nlet validLinks = [];\nif (linkMatch) {\n  for (let l of linkMatch) {\n    let clean = l.replace(/<\\/?link[^>]*>/g, '')\n                 .replace(/<link\\s+href=\"([^\"]+)\"[^>]*>/g, '$1')\n                 .trim();\n    if (clean.startsWith('http') && !clean.includes('comments')) validLinks.push(clean);\n  }\n}\nif (validLinks.length > 0) {\n  let picked = validLinks[Math.floor(Math.random() * validLinks.length)];\n  return [{ json: { link: picked, is_empty: false } }];\n}\nreturn [{ json: { link: 'https://vnexpress.net', is_empty: true } }];"
